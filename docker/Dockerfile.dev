FROM elixir:1.18-otp-26

RUN apt-get update && apt-get install -y nodejs npm curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN mix local.hex --force && mix local.rebar --force

ENV MIX_ENV=dev

# Umbrella layout — copy root + app manifests first for dep cache
COPY mix.exs mix.lock ./
COPY config config
COPY apps/engine/mix.exs apps/engine/
COPY apps/server/mix.exs apps/server/

RUN mix deps.get
RUN mix deps.compile

# Copy application sources
COPY apps apps

RUN mix compile

EXPOSE 4000

CMD ["mix", "phx.server"]
